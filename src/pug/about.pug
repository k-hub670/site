doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='Learn about CNC Auto Service, a family-owned auto repair shop in Lilburn, GA serving Metro Atlanta with honest, quality repairs since 2012.')
        meta(name='author', content='CNC Auto Service')

        title About CNC Auto Service | Lilburn, GA Auto Repair

        include includes/css.pug

    body.d-flex.flex-column.h-100

        main.flex-shrink-0

            include includes/navbar.pug

            header.bg-dark.py-5
                .container.px-5
                    .row.justify-content-center
                        .col-lg-8.text-center.text-white
                            h1.display-5.fw-bolder.mb-3 About CNC Auto Service
                            p.lead.text-white-50
                                | A family-owned auto repair shop built on honesty, hard work, and treating every customer like a neighbor.

            section.py-5
                .container.px-5.my-5
                    .row.gx-5.justify-content-center
                        .col-lg-8
                            h2.fw-bolder.mb-4 Our Story
                            p.text-muted.mb-4
                                | CNC Auto Service & Used Tires opened its doors in Lilburn, Georgia in 2012 with a simple goal: provide Metro Atlanta drivers with honest, quality auto repair at a fair price. Over a decade later, that mission hasn't changed.
                            p.text-muted.mb-4
                                | We're a full-service shop handling everything from oil changes and brake jobs to auto body repair, collision work, and tire replacement. Our technicians take the time to explain what's wrong and what it'll take to fix it - no upselling, no surprises.
                            p.text-muted.mb-4
                                | Located on Pleasant Hill Rd, we're proud to be the go-to auto shop for families across Lilburn, Snellville, Norcross, and the greater Atlanta area.

            section.py-5.bg-light
                .container.px-5.my-5
                    .row.justify-content-center.mb-5
                        .col-lg-8.text-center
                            h2.fw-bolder Our Services
                            p.lead.text-muted Whatever your vehicle needs, we handle it.
                    .row.gx-5
                        .col-md-6.col-xl-4.mb-5
                            .card.h-100.shadow-sm.border-0
                                .card-body.p-4
                                    h5.fw-bolder Auto Body & Collision
                                    p.text-muted Expert dent repair, paint matching, and collision restoration.
                        .col-md-6.col-xl-4.mb-5
                            .card.h-100.shadow-sm.border-0
                                .card-body.p-4
                                    h5.fw-bolder Brakes & Tires
                                    p.text-muted Brake pads, rotors, new & used tires, alignments, and rotations.
                        .col-md-6.col-xl-4.mb-5
                            .card.h-100.shadow-sm.border-0
                                .card-body.p-4
                                    h5.fw-bolder Diagnostics & Electrical
                                    p.text-muted Computer diagnostics, check engine light, wiring, and sensor repairs.
                        .col-md-6.col-xl-4.mb-5
                            .card.h-100.shadow-sm.border-0
                                .card-body.p-4
                                    h5.fw-bolder A/C & Heating
                                    p.text-muted A/C recharge, heater repair, and full climate system service.
                        .col-md-6.col-xl-4.mb-5
                            .card.h-100.shadow-sm.border-0
                                .card-body.p-4
                                    h5.fw-bolder Oil Changes & Maintenance
                                    p.text-muted Routine oil changes and scheduled maintenance for all makes & models.
                        .col-md-6.col-xl-4.mb-5
                            .card.h-100.shadow-sm.border-0
                                .card-body.p-4
                                    h5.fw-bolder Emissions & Inspections
                                    p.text-muted Georgia emissions testing and vehicle inspections, fast and reliable.

            section.py-5.bg-primary
                .container.px-5.my-5
                    .row.justify-content-center
                        .col-lg-8.text-center
                            h2.fw-bolder.text-white.mb-4 Ready to bring your car in?
                            a.btn.btn-light.btn-lg.px-5(href='tel:+17709253106') Call (770) 925-3106

        include includes/footer.pug

        include includes/scripts.pug
